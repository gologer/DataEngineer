# เทมเพลตตั้งค่า — copy ไฟล์นี้เป็น .env แล้วกรอกค่าจริง
#   PowerShell:  Copy-Item .env.example .env

# GCP project สำหรับคิดโควตา BigQuery (จำเป็น)
GOOGLE_CLOUD_PROJECT=your-project-id

# path ไฟล์ service account JSON (ไม่จำเป็น ถ้า login ด้วย gcloud auth application-default login แล้ว)
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
